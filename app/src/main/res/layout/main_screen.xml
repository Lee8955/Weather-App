<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:spacing="8dp"
        >


        <!-- Heading -->
    <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Weekly Weather Input"
            android:textColor="@color/purple_200"
            android:textSize="30sp"
            android:textStyle="bold"/>

        <!--    Day Spinner -->

    <Spinner
        android:id="@+id/spinnerDays"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="12dp"
        android:background="#FFFFFF"
        />

        <!-- Minimum Temperature -->

    <EditText
        android:id="@+id/editMin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="#FFFFFF"
        android:hint="Enter Minimum Temperature"
        android:inputType="number"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:textSize="18sp"/>

        <!-- Maximum Temperature -->

    <EditText
        android:id="@+id/editMax"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="#FFFFFF"
        android:hint="Enter Maximum Temperature"
        android:inputType="number"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:textSize="18sp"/>

        <!-- Weather Condition -->

    <EditText
        android:id="@+id/editCondition"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="#FFFFFF"
        android:hint="Enter Weather Condition"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:textSize="18sp"/>

        <!-- Save Button -->

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="SAVE DATA"
        android:textStyle="bold"
        android:padding="12dp"
        android:textSize="18sp"/>

        <!-- Average Button -->

    <Button
        android:id="@+id/btnAverage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="CALCULATE AVERAGE"
        android:textStyle="bold"
        android:padding="12dp"
        android:textSize="18sp"
        />

        <!-- Details Button -->

    <Button
        android:id="@+id/btnDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="VIEW DETAILS"
        android:textStyle="bold"
        android:padding="12dp"
        android:textSize="18sp"
        />

        <!-- Clear Button -->

    <Button
        android:id="@+id/btnClear"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="CLEAR DATA"
        android:textStyle="bold"
        android:padding="12dp"
        android:textSize="18sp"
        />

        <!-- Exit Button -->
        <Button
            android:id="@+id/btnExit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Average Weather Temperature"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"/>

        <!-- Average Output -->

        <TextView
            android:id="@+id/txtAverage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Average Weekly Temperature"
            android:textSize="24sp"
            android:textStyle="bold"/>

    </LinearLayout>

</ScrollView>